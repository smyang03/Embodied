{
  "hf_token":         "",

  "image_dir":        "/data/JPEGImages",
  "output_dir":       "/data/dataset",
  "model_path":       "models/LocateAnything-3B",
  "model_save_dir":   "./models",

  "prompts": [
    { "name": "person",   "id": 0 },
    { "name": "car",      "id": 1 },
    { "name": "bicycle",  "id": 2 }
  ],

  "max_input_size": 1024,

  "iou_threshold":  0.45,
  "nms_mode":       "per_class",

  "generation_mode":  "hybrid",
  "temperature":      0.7,
  "max_new_tokens":   8192,

  "debug_interval":    1000,
  "debug_output_dir":  "./debug_images",

  "gpu":                 "0",
  "resume":              false,
  "expandable_segments": true
}
